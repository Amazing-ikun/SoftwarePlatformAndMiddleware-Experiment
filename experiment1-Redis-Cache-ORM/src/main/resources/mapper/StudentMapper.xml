<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.repository.StudentMapper">

    <!-- 结果映射 -->
    <resultMap id="StudentWithCourses" type="com.example.demo.entity.Student">
        <id    column="s_id"    property="id"/>
        <result column="s_name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="phone"  property="phone"/>
        <result column="major"  property="major"/>

        <!-- 一对多：课程集合 -->
        <collection property="courses" ofType="com.example.demo.entity.Course">
            <id          column="c_id"          property="id"/>
            <result      column="c_name"        property="name"/>
            <result      column="credits"       property="credits"/>
            <result      column="description"    property="description"/>
        </collection>
    </resultMap>

    <!-- 查询 -->
    <select id="findByIdWithCourses" resultMap="StudentWithCourses">
        SELECT
        s.id          AS s_id,
        s.name        AS s_name,
        s.gender,
        s.phone,
        s.major,
        c.id          AS c_id,
        c.name        AS c_name,
        c.credit      AS credits,
        c.description
        FROM student s
        LEFT JOIN course c ON s.id = c.student_id
        WHERE s.id = #{id}
    </select>

</mapper>
